{
  "info": {
    "name": "Task Manager API",
    "description": "Colección completa de endpoints para la Task Manager API.\n\nFlujo de uso:\n1. Ejecuta 'Registrar usuario' o 'Login'\n2. El token se guarda automáticamente en la variable {{token}}\n3. El resto de peticiones lo usan sin configuración adicional",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Se rellena automáticamente al hacer login o registro"
    }
  ],
  "item": [
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "Registrar usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Guarda el token automáticamente para las siguientes peticiones",
                  "var response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.collectionVariables.set('token', response.token);",
                  "    console.log('Token guardado correctamente');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Javi\",\n  \"email\": \"javi@test.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/registro",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "registro"]
            },
            "description": "Registra un nuevo usuario y devuelve un JWT. El token se guarda automáticamente en {{token}}."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Guarda el token automáticamente para las siguientes peticiones",
                  "var response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.collectionVariables.set('token', response.token);",
                  "    console.log('Token guardado correctamente');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"javi@test.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Inicia sesión con email y contraseña. El token se guarda automáticamente en {{token}}."
          }
        }
      ]
    },
    {
      "name": "Tareas",
      "item": [
        {
          "name": "Listar tareas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tareas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tareas"]
            },
            "description": "Devuelve todas las tareas del usuario autenticado."
          }
        },
        {
          "name": "Crear tarea",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Mi primera tarea\",\n  \"descripcion\": \"Descripción de la tarea\",\n  \"completada\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tareas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tareas"]
            },
            "description": "Crea una nueva tarea asociada al usuario autenticado."
          }
        },
        {
          "name": "Actualizar tarea",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Tarea actualizada\",\n  \"descripcion\": \"Nueva descripción\",\n  \"completada\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tareas/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tareas", "1"]
            },
            "description": "Actualiza los datos de una tarea existente. Cambia el '1' del final por el ID real de la tarea."
          }
        },
        {
          "name": "Eliminar tarea",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tareas/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tareas", "1"]
            },
            "description": "Elimina una tarea. Cambia el '1' del final por el ID real de la tarea."
          }
        }
      ]
    }
  ]
}
